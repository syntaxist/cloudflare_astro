---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="My Blog">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <section class="mb-16">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 tracking-tight">
        My Blog
      </h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        Thoughts on technology, projects, and ideas.
      </p>
    </section>

    <section>
      <div class="divide-y divide-gray-100 dark:divide-gray-800">
        {posts.map((post) => (
          <div class="py-2">
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
